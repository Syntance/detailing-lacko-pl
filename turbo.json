{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_JWT_SECRET",
    "MAGAZYN_ADMIN_ALLOWLIST",
    "MODULY_CMS_PAGE_IDS",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_GA4_ID",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_META_PIXEL_ID",
    "NEXT_PUBLIC_CLARITY_ID",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "RESEND_REPLY_TO",
    "CONTACT_INBOX_EMAIL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_FILE_URL",
    "NEXT_PUBLIC_S3_FILE_URL",
    "FEATURE_ANALYTICS_PANEL",
    "GA4_PROPERTY_ID",
    "GA4_SERVICE_ACCOUNT_JSON",
    "POSTHOG_PERSONAL_API_KEY",
    "POSTHOG_PROJECT_ID",
    "POSTHOG_HOST",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
