# Baza danych (Postgres — CMS, cennik, formularze, sesje admina)
DATABASE_URL=postgresql://user:pass@host:5432/detailing_lacko

# JWT sesji administratora panelu (/magazyn) — min. 32 znaki
AUTH_JWT_SECRET=change-me-in-production-min-32-chars

# Seed pierwszego admina (używane tylko przez `pnpm migrate`)
MAGAZYN_ADMIN_EMAIL=
MAGAZYN_ADMIN_PASSWORD=

# Opcjonalna allowlista e-maili admina (CSV). Pusta = brak ograniczenia.
# MAGAZYN_ADMIN_ALLOWLIST=kamil@syntance.com

# Identyfikatory podstron CMS do odczytu w storefront (zgodne z moduly.config.ts)
MODULY_CMS_PAGE_IDS=home

# Publiczny URL witryny (linki w mailach i panelu)
NEXT_PUBLIC_SITE_URL=https://detailing-lacko.pl

# Resend — powiadomienia z formularza kontaktowego
RESEND_API_KEY=
# RESEND_FROM=Detailing Łącko <kontakt@detailing-lacko.pl>
# RESEND_REPLY_TO=kontakt@detailing-lacko.pl
# CONTACT_INBOX_EMAIL=kontakt@detailing-lacko.pl

# Rate limiting (login, rezerwacje, formularz kontaktowy).
# Na PRODUKCJI wymagane — bez Upstash limiter działa tylko in-memory per
# instancję serverless (loguje błąd konfiguracji). Darmowy plan wystarczy.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 — uploady CMS z panelu (opcjonalnie w dev)
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FILE_URL=
# NEXT_PUBLIC_S3_FILE_URL=

# Analityka client-side (storefront, produkcja)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=

# Analityka panelu (GA4 + PostHog, server-only)
FEATURE_ANALYTICS_PANEL=1
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://eu.posthog.com
